# =============================================================================
#  CheckoutSeguro — Configuração de Ambiente
#  Copie este arquivo para .env e preencha os valores:
#    cp .env.example .env
# =============================================================================

# ── Servidor Local ────────────────────────────────────────────────────────────
# Porta em que o app local será executado (padrão: 7432)
CHECKOUTSEGURO_PORT=7432

# Modo de execução: production | development
CHECKOUTSEGURO_ENV=development

# Nível de log: debug | info | warning | error
CHECKOUTSEGURO_LOG_LEVEL=info

# ── Banco de Dados ────────────────────────────────────────────────────────────
# Caminho absoluto para o banco de dados SQLite local
# Em produção, use ~/.checkoutseguro/wallet/identity.db
CHECKOUTSEGURO_DB_PATH=./app/wallet/identity.db

# ── HTTPS Local ───────────────────────────────────────────────────────────────
# Habilitar HTTPS local (recomendado para produção)
CHECKOUTSEGURO_USE_HTTPS=false

# Caminhos para o certificado TLS (gerado por deploy/certs/generate-cert.sh)
CHECKOUTSEGURO_CERT_FILE=./deploy/certs/cert.pem
CHECKOUTSEGURO_KEY_FILE=./deploy/certs/key.pem

# ── Fazendinha E-commerce (Laboratório) ──────────────────────────────────────
# Porta da loja de testes
FAZENDINHA_PORT=8001

# Caminho do banco de dados de pedidos
FAZENDINHA_DB_PATH=./fazendinha-ecommerce/orders.db

# URL do app CheckoutSeguro (para verificação de assinaturas)
CHECKOUTSEGURO_APP_URL=http://127.0.0.1:7432
